# ─── WhatsApp Cloud API ────────────────────────────────────────────────────────
# Bearer token généré dans Meta Developer Console > WhatsApp > API Setup
WA_TOKEN=

# Phone Number ID affiché dans API Setup (ex: 123456789012345)
WA_PHONE_ID=

# Token libre que tu choisis lors de la config du webhook Meta
WA_VERIFY_TOKEN=

# ─── Sécurité PII ──────────────────────────────────────────────────────────────
# Salt pour SHA-256 des wa_id — min 32 chars aléatoires, NE PAS CHANGER après prod
WA_SALT=

# Clé AES-256-GCM pour chiffrement wa_id — exactement 64 chars hex (= 32 bytes)
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WA_ENCRYPTION_KEY=

# ─── Base de données ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/delivery_db

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Secrets DIFFÉRENTS l'un de l'autre — min 32 chars chacun
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Cloudflare R2 (compatible S3) ─────────────────────────────────────────────
# Account ID visible dans le dashboard Cloudflare > R2
R2_ACCOUNT_ID=

# Créer dans R2 > Manage R2 API Tokens > Create API Token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nom exact du bucket R2
R2_BUCKET_NAME=

# URL publique du bucket si activée (ex: https://pub-xxx.r2.dev), sinon laisser vide
R2_PUBLIC_URL=

# ─── Firebase Cloud Messaging (optionnel) ──────────────────────────────────────
# JSON complet du service account Firebase (sur une seule ligne, sans retour à la ligne)
# Laisser vide pour désactiver les notifications push
FCM_SERVICE_ACCOUNT=

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Origines autorisées séparées par des virgules (laisser vide = tout autoriser)
# Ex: https://admin.monapp.com,http://localhost:3000
ALLOWED_ORIGINS=

# ─── Call Center ───────────────────────────────────────────────────────────────
# Numéro de téléphone du Call Center affiché dans l'app livreur (format international ex: +22220001234)
CC_PHONE=

# ─── Serveur ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Durée des tokens JWT (format ms/vercel syntax)
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=30d
